{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "AI Stock Agent",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "fs": {
        "all": true,
        "scope": ["$APPDATA/*", "$APPDATA/**", "$DOCUMENT/*"]
      },
      "path": { "all": true },
      "shell": {
        "all": false,
        "open": true
      },
      "notification": { "all": true },
      "dialog": { "all": true }
    },
    "bundle": {
      "active": true,
      "category": "Finance",
      "copyright": "",
      "deb": { "depends": [] },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.ai-stock-agent.app",
      "longDescription": "AI 炒股 Agent 系统 - 本地运行的个人投资助手",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "AI 炒股 Agent 系统",
      "targets": ["nsis", "msi"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: https://*; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://* http://localhost:* http://127.0.0.1:* ipc: http://ipc.localhost; font-src 'self' data:"
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 860,
        "resizable": true,
        "title": "AI Stock Agent",
        "width": 1440,
        "minWidth": 1080,
        "minHeight": 720,
        "center": true,
        "theme": "Dark"
      }
    ]
  }
}
